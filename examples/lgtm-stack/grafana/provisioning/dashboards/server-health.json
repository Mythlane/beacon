{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "uid": "beacon-server-health",
  "title": "Server Health",
  "tags": ["beacon", "hytale"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "TPS",
      "description": "Ticks per second per world. Hytale baseline TPS = 30. Red threshold = 27 (10% drop).",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 30,
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 27 },
              { "color": "green", "value": 28.5 }
            ]
          },
          "custom": {
            "thresholdsStyle": { "mode": "line" }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "min(hytale_tps_per_second) by (hytale_world_name)",
          "legendFormat": "{{hytale_world_name}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "MSPT (p50 / p95 / p99)",
      "description": "Milliseconds per tick — p50/p95/p99 from the hytale_mspt histogram.",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "histogram_quantile(0.50, sum(rate(hytale_mspt_milliseconds_bucket[5m])) by (le, hytale_world_name))",
          "legendFormat": "p50 — {{hytale_world_name}}"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "histogram_quantile(0.95, sum(rate(hytale_mspt_milliseconds_bucket[5m])) by (le, hytale_world_name))",
          "legendFormat": "p95 — {{hytale_world_name}}"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "histogram_quantile(0.99, sum(rate(hytale_mspt_milliseconds_bucket[5m])) by (le, hytale_world_name))",
          "legendFormat": "p99 — {{hytale_world_name}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "JVM Memory (heap + non-heap)",
      "description": "Stacked JVM memory usage by type (heap / non_heap).",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "fillOpacity": 30,
            "stacking": { "mode": "normal", "group": "A" }
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "sum(jvm_memory_used_bytes) by (jvm_memory_type, jvm_memory_pool_name)",
          "legendFormat": "{{type}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "GC pause time + frequency",
      "description": "GC pause rate (left axis: seconds/sec) and collection rate (right axis: count/sec).",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": [
          {
            "matcher": { "id": "byFrameRefID", "options": "B" },
            "properties": [
              { "id": "unit", "value": "ops" },
              { "id": "custom.axisPlacement", "value": "right" }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "rate(jvm_gc_duration_seconds_sum[5m])",
          "legendFormat": "pause — {{gc}}"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "rate(jvm_gc_duration_seconds_count[5m])",
          "legendFormat": "freq — {{gc}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Threads count",
      "description": "Live JVM threads.",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 500 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "jvm_thread_count",
          "legendFormat": "threads"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Players online (per world)",
      "description": "Stacked count of players online, grouped by world.",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "fillOpacity": 30,
            "stacking": { "mode": "normal", "group": "A" }
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "sum(hytale_players_online_ratio) by (hytale_world_name)",
          "legendFormat": "{{hytale_world_name}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "gauge",
      "title": "CPU utilization",
      "description": "Process CPU utilization (percent of all cores).",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 85 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "jvm_cpu_recent_utilization_ratio * 100",
          "legendFormat": "cpu"
        }
      ]
    }
  ]
}
